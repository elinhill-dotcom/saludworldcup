generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id            String         @id @default(cuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  predictions   Prediction[]
  knockoutPick  KnockoutPick?
}

model Match {
  id          Int          @id
  matchNumber Int?
  dayLabel    String
  kickoffAt   DateTime
  homeTeam    String
  awayTeam    String
  groupCode   String?
  stage       String
  broadcaster String?
  featured    Boolean      @default(false)
  homeScore   Int?
  awayScore   Int?
  finished    Boolean      @default(false)
  predictions Prediction[]
  chatMessages MatchChatMessage[]
}

model Prediction {
  id        String @id @default(cuid())
  playerId  String
  matchId   Int
  homeScore Int
  awayScore Int
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId])
}

model KnockoutPick {
  id         String  @id @default(cuid())
  playerId   String  @unique
  sf1Home    String?
  sf1Away    String?
  sf2Home    String?
  sf2Away    String?
  finalHome  String?
  finalAway  String?
  bronzeHome String?
  bronzeAway String?
  champion   String?
  player     Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model KnockoutAnswer {
  id         Int     @id @default(1)
  sf1Home    String?
  sf1Away    String?
  sf2Home    String?
  sf2Away    String?
  finalHome  String?
  finalAway  String?
  bronzeHome String?
  bronzeAway String?
  champion   String?
  set        Boolean @default(false)
}

model WallComment {
  id        String   @id @default(cuid())
  name      String
  message   String
  createdAt DateTime @default(now())
}

model MatchChatMessage {
  id        String   @id @default(cuid())
  matchId   Int
  name      String
  message   String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}
